{
  "name": "yoyo-champion",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:next": "pnpm --filter @yoyo/next dev",
    "dev:expo": "pnpm --filter @yoyo/expo dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "overrides": {
      "@types/react": "^18.3.1",
      "@types/react-dom": "^18.3.1"
    }
  }
}
