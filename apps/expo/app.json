{
  "expo": {
    "name": "YoYo Champion",
    "slug": "yoyo-champion",
    "scheme": "yoyochampion",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1CB0F6"
    },
    "platforms": ["ios", "android"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yoyochampion.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1CB0F6"
      },
      "package": "com.yoyochampion.app"
    },
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      [
        "@react-native-async-storage/async-storage",
        {
          "exclude": []
        }
      ]
    ]
  }
}
