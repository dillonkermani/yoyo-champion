{
  "name": "@yoyo/expo",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "build": "expo export",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "clean": "rm -rf .expo"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.6",
    "@expo/metro-runtime": "^4.0.1",
    "@react-native-async-storage/async-storage": "^1.23.1",
    "@tamagui/config": "^1.110.2",
    "@tamagui/core": "^1.110.2",
    "@tanstack/react-query": "^5.0.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@yoyo/api": "workspace:*",
    "@yoyo/data": "workspace:*",
    "@yoyo/store": "workspace:*",
    "@yoyo/ui": "workspace:*",
    "expo": "~52.0.0",
    "expo-router": "~4.0.0",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-native": "0.76.3",
    "react-native-screens": "~4.4.0",
    "solito": "^4.0.0",
    "superjson": "^2.2.1",
    "tamagui": "^1.110.2",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@tamagui/babel-plugin": "2.0.0-rc.22",
    "@types/jest": "^29.5.12",
    "@types/react": "~18.3.0",
    "babel-plugin-module-resolver": "^5.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.0",
    "typescript": "^5.4.2"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!(\\.pnpm/[^/]*/node_modules/)?(react-native|@react-native|expo|@expo|tamagui|@tamagui|@yoyo))"
    ]
  }
}
